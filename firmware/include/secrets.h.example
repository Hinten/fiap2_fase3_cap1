#ifndef CARDIOIA_SECRETS_H
#define CARDIOIA_SECRETS_H

// Wokwi: Wi-Fi simulado tem SSID = "Wokwi-GUEST" e senha vazia.
#define WIFI_SSID      "Wokwi-GUEST"
#define WIFI_PASSWORD  ""

// HiveMQ Cloud Serverless (free tier).
// Crie cluster em https://www.hivemq.com/mqtt-cloud-broker/ e copie aqui.
#define MQTT_HOST      "SEU-CLUSTER.s2.eu.hivemq.cloud"
#define MQTT_PORT      8883
#define MQTT_USER      "seu_usuario"
#define MQTT_PASSWORD  "sua_senha"

// Identificação do paciente/dispositivo. Aparece em todos os tópicos.
#define DEVICE_ID      "cardioia-01"

#endif  // CARDIOIA_SECRETS_H
